# This file documents environment variables needed for the project
# Copy this file to .env and fill in your values

# ===== BACKEND =====
# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# Server Port
PORT=9999

# JWT Secret Key
SECRET=your_secret_key_here

# ===== FRONTEND =====
# Backend API URL (use for frontend requests)
REACT_APP_API_URL=http://localhost:9999

# ===== DEPLOYMENT (Render) =====
# For Render deployment, update these values in Render Dashboard:
# Backend: Add MONGODB_URI, PORT, SECRET as Environment Variables
# Frontend: Add REACT_APP_API_URL pointing to your Render backend URL
